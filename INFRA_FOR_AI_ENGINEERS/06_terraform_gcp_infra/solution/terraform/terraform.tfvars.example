project_id      = "your-gcp-project-id"
region          = "us-central1"
service_name    = "ai-model-serving"
container_image = "us-central1-docker.pkg.dev/your-project/cloud-run-source-deploy/ai-api:latest"
alert_email     = "your-email@gmail.com"

